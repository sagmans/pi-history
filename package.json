{
	"name": "@sagmans/pi-history",
	"version": "0.1.4",
	"description": "Ghost completion for prompt history in pi's TUI",
	"license": "MIT",
	"files": [
		"index.ts",
		"src",
		"config.json",
		"config.local.example.json",
		"resources"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sagmans/pi-history.git"
	},
	"homepage": "https://github.com/sagmans/pi-history#readme",
	"bugs": "https://github.com/sagmans/pi-history/issues",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"history",
		"ghost-completion"
	],
	"type": "module",
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"scripts": {
		"test": "npm run test:unit && npm run test:npm",
		"test:unit": "node --experimental-transform-types --test test/*.test.ts",
		"test:npm": "bash test/npm/run.sh",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"audit": "npm audit --audit-level=high",
		"smoke:herdr": "bash scripts/maintainer-smoke-herdr.sh",
		"verify": "npm run check && npm run typecheck && npm test",
		"verify:ci": "npm run audit && npm run verify"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@earendil-works/pi-coding-agent": "0.81.1",
		"@earendil-works/pi-tui": "0.81.1",
		"@types/node": "24.13.2",
		"husky": "9.1.7",
		"typescript": "7.0.2"
	}
}
