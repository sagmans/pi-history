{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "index.ts",
    "src/**/*",
    "test/**/*"
  ]
}
